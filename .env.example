# Universe MCP — environment variables
# Copy this file to .env and fill in values.

# PostgreSQL connection string (optional).
# When set, Universe enables memory recall and skill matching.
# When unset, Universe still provides routing decisions from graph analysis alone.
# Example: postgresql://universe:secret@localhost:5432/universe
DATABASE_URL=

# Override the config file location (optional).
# Default: ~/.universe/config.yaml
# UNIVERSE_CONFIG=/path/to/config.yaml
